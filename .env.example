# TreinoFácil — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com as chaves do seu projeto Supabase.
# Supabase Dashboard → Project Settings → API

# URL do projeto (pública)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Chave anônima (pública — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role (SECRETA — somente servidor, ignora RLS). NUNCA prefixe com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
